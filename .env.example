# Application
APP_ENV=development
APP_NAME=AI Resume & Job Match Agent
APP_VERSION=0.1.0
APP_DEBUG=false
APP_API_KEYS=
APP_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
APP_CORS_ORIGINS=
APP_MAX_UPLOAD_BYTES=10485760
APP_MAX_JOB_DESCRIPTION_CHARS=50000
APP_DATA_RETENTION_DAYS=30
APP_RATE_LIMIT_PER_MINUTE=30

# AI provider: "local" runs without external credentials; "openai" uses the Responses API.
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=3

# Persistence
DATABASE_URL=sqlite+aiosqlite:///./data/resume_matcher.db
DATABASE_ECHO=false
DATABASE_AUTO_CREATE_SCHEMA=true
STORAGE_PATH=./data/uploads

# Docker Compose PostgreSQL values (development only; change before deployment)
POSTGRES_DB=resume_matcher
POSTGRES_USER=resume_matcher
POSTGRES_PASSWORD=change-me-before-production

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
